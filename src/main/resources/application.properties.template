spring.application.name=spring-ai-project

# OpenAI API Key (Required for Spring AI ChatClient)
spring.ai.openai.api-key=YOUR_OPENAI_API_KEY_HERE
spring.ai.openai.base-url=http://192.168.100.190:11434
spring.ai.openai.chat.options.model=llama3.2:latest

# WordPress Blog Poster Agent Configuration
wordpress.url=https://YOUR_WORDPRESS_SITE.com
wordpress.username=YOUR_USERNAME_OR_EMAIL
wordpress.password=YOUR_APPLICATION_PASSWORD

server.error.include-stacktrace=always
spring.ai.openai.client.timeout=10m

# Ollama Global Configuration
spring.ai.ollama.base-url=http://192.168.100.190:11434
logging.level.org.springframework.ai=DEBUG
spring.autoconfigure.exclude=org.springframework.ai.model.ollama.autoconfigure.OllamaChatAutoConfiguration
